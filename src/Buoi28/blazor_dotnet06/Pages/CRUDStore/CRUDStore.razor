@page "/crud-store"

@inject StoreService _storeService


@implements IDisposable

<div class="container">
    <h3>Quản lý store</h3>
    
    <div class="card shadow-sm border-0">
     
        <div class="card-header bg-dark text-white">
            
            <div class="row align-items-center g-3">
                <div class="col-md-6">
                    <h4 class="mb-0">Danh sách cửa hàng</h4>
                </div>

                <div class="col-md-6">
                    <form action="" method="get">
                        <div class="input-group">
                            <input type="text" name="keyword" class="form-control"
                                   placeholder="Tìm kiếm cửa hàng theo tên..." />
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-search"></i>
                                Tìm kiếm
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="card-body">
               <a href="/create-store" class="btn btn-primary my-2">
        Create store
    </a>
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle mb-0">
                    <thead class="table-dark text-center">
                        <tr>
                            <th>ID</th>
                            <th>Hình ảnh</th>
                            <th>Tên cửa hàng</th>
                            <th>Alias</th>
                            @* <th>Latitude</th>
                <th>Longtitude</th> *@
                            <th>Mô tả</th>
                            <th>

                            </th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (StoreViewModel item in _storeService.lstStore)
                        {
                            <tr>

             
                                <td class="text-center">@item.Id</td>

                                <td class="text-center">
                                    <img src="@item.Image" alt="Nguyên Sneaker" class="img-thumbnail"
                                         style="width: 90px; height: 60px; object-fit: cover;" />
                                </td>

                                <td class="fw-semibold">@item.Name</td>
                                <td>@item.Alias</td>
                                @* <td>@item.Latitude</td>
                <td>@item.Longtitude</td> *@
                                <td>
                                    @if (item.Description.Length > 30)
                                    {
                                        <p> @item.Description.Substring(0, 30) ...</p>
                                    }
                                    else
                                    {
                                        <p>@item.Description</p>
                                    }

                    
                                </td>

            
                                <td style="width:150px">
                                    <a href="/store-detail/@item.Id" class="btn btn-primary mx-2">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <button @onclick="@( async e => await _storeService.DeleteStore(item.Id) )" class="btn btn-danger">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }

              
                    </tbody>
                </table>
            </div>

        </div>

        <div class="card-footer d-flex justify-content-between align-items-center">
            <span>Hiển thị 1 đến 2 của 2 kết quả</span>

            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item disabled">
                        <a class="page-link" href="#">Trước</a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link" href="#">1</a>
                    </li>
                    <li class="page-item disabled">
                        <a class="page-link" href="#">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>

    </div>
</div>



@code {

    [SupplyParameterFromQuery(Name = "keyword")]
    public string keyword { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        _storeService.OnChange += StateHasChanged;
        //gọi api getAll khi trang vừa load
        await _storeService.getAllStore(keyword);

    }





    public void Dispose()
    {
        _storeService.OnChange -= StateHasChanged;
    }
}