
<!-- Modal trigger button -->


<!-- Modal Body -->
<!-- if you want to close by clicking outside the modal, delete the last endpoint:data-bs-backdrop and data-bs-keyboard -->
<div
    class="modal fade"
    id="modalId"
    tabindex="-1"
    data-bs-backdrop="static"
    data-bs-keyboard="false"
    
    role="dialog"
    aria-labelledby="modalTitleId"
    aria-hidden="true"
>
    <div
        class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-sm"
        role="document"
    >
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitleId">
                    Details of @phone.TenSp
                </h5>
                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close"
                ></button>
            </div>
            <div class="modal-body">
                @* Display phone details here *@
                <img src="@phone.HinhAnh" alt="@phone.TenSp" class="img-fluid mb-3" />
                <p><strong>Name:</strong> @phone.TenSp</p>
                <p><strong>Screen:</strong> @phone.ManHinh</p>
                <p><strong>Operating System:</strong> @phone.HeDieuHanh</p>
                <p><strong>Front Camera:</strong> @phone.CameraTruoc</p>
                <p><strong>Back Camera:</strong> @phone.CameraSau</p>
                <p><strong>RAM:</strong> @phone.Ram</p>
                <p><strong>Storage:</strong> @phone.Rom</p>
                <p><strong>Price:</strong> @phone.GiaBan.ToString("N0") VND</p>

            </div>
            <div class="modal-footer">
                <button
                    type="button"
                    class="btn btn-secondary"
                    data-bs-dismiss="modal"
                >
                    Close
                </button>
                <button type="button" class="btn btn-primary">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Optional: Place to the bottom of scripts -->
<script>
    const myModal = new bootstrap.Modal(
        document.getElementById("modalId"),
        options,
    );
</script>


@code{
    [Parameter]
    public PhoneCartVM? phone { get; set; }
}