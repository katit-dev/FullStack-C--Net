@page "/phone"
@using Car_Phone.Components.Pages.BT_Car

<ExerciseCart>
    <ModalCart gioHang="@carts" />
    <ModalPhone phone="@phone" />
    <PhoneList>
        @foreach (PhoneCartVM sp in phones)
        {
            <PhoneItem sp="@sp" AddToCart="ThemGioHang" ViewDetails="XemChiTiet"/>
        }
    </PhoneList>
</ExerciseCart>

