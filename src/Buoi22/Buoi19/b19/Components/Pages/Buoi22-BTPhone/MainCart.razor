    }
};

           
    // cart: chua 1 san pham
    // cart ở đây cần bổ sung thêm cột số lượng  
    List<CartItemVM> carts = new List<CartItemVM>()
    {
        
    };

    // card dang xem chi tiet

    // them gio hang
    void ThemGioHang(PhoneCartVM sp)
    {
        // nhan vao phone, nen phai chuyen doi phone sang cart
        // FirstOrDefault: khong tim thay tra ve default (null), tim thay tra ve sp trong gio hang
        // First: khong tim thay tra ve loi, tim thay tra ve sp trong gio hang

        // TH1: sp chua co trong gio hang
        var find = carts.FirstOrDefault(x => x.MaSp == sp.MaSp);
        if(find == null){
            var cart = new CartItemVM
            {
                MaSp = sp.MaSp,
                TenSp = sp.TenSp,
                GiaBan = sp.GiaBan,
                HinhAnh = sp.HinhAnh,
                SoLuong = 1
            };
            carts.Add(cart);
        }
        // TH2: sp da co trong gio hang, tang so luong len 1
        else{
            find.SoLuong += 1;
        }
    }
}