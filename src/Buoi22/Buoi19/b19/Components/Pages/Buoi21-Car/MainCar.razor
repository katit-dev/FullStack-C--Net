@page "/car"

@using b19.Components.Pages.eventCallback


<ExerciseCarStore>
    <ModalCar Item="@Xe"/>

        <ProductListCar>
            @foreach (var item in lstCar)
            {
                <ProductItemCar Item="@item" XemChiTiet="ShowDetail"/>
            }
        </ProductListCar>

</ExerciseCarStore>


@code {
    // ds xe
    // products/products/red-car.jpg
    List<CarProductVm> lstCar = new List<CarProductVm>(){
            
            new CarProductVm(){Id=1, Name="Red Car", Img="products/products/red-car.jpg", Price=100},
            new CarProductVm(){Id=2, Name="Silver Car", Img="products/products/silver-car.jpg", Price=200},
            new CarProductVm(){Id=3, Name="Steel Car", Img="products/products/steel-car.jpg", Price=300},
            new CarProductVm(){Id=4, Name="Black Car", Img="products/products/black-car.jpg", Price=400},
            };

    @* cần có 1 biến để lưu trữ xe được chọn, xe truyền vào cho modal *@
    CarProductVm Xe = new CarProductVm();

    @* hàm nhận vào 1 xe và gán cho biến Xe của modal *@
    @* hàm này đưuọc truyền cho ProductItemCar *@
    public void ShowDetail(CarProductVm item)
    {
        Xe = item;
    }

}