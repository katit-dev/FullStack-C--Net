@inject BurgerService _burgerService
@implements IDisposable

<div class="col-md-6">
    <h3>Burger</h3>
    <div class="breadTop"></div>
    @foreach(var item in _burgerService.lstIngredient)
    {
          for(int i = 0; i < item.quantity; i++)
          {
            <div class="@item.name"></div>
          }
    }

    <div class="breadBottom"></div>
</div>


@code{
    // ============ Logic Method ===================





    // ============ Logic Method ===================

    protected override async Task OnInitializedAsync()
    {
        _burgerService.OnChange += StateHasChanged;
    }
     public void Dispose()
    {
       
        _burgerService.OnChange -= StateHasChanged;
    }

}


